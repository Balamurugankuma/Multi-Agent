# Velverse AI — Frontend Environment Variables
# Copy this file to .env and fill in your values

# Backend API URL (leave as-is for local dev)
VITE_API_URL=http://localhost:5000/api

# OpenAI API Key — used by the AI Chatbot on the Home page
# Get yours at: https://platform.openai.com/api-keys
# If left blank, users can enter their key in the chat UI
VITE_OPENAI_API_KEY=sk-your-openai-key-here

# OpenAI API Key — used by the Home page chatbot
VITE_OPENAI_API_KEY=your_openai_api_key_here
