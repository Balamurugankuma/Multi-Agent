# ════════════════════════════════════════════════════════════
#  Velverse AI + TaskFlow — Backend Environment Variables
#  Copy to .env and fill in your real values
# ════════════════════════════════════════════════════════════

PORT=5000
NODE_ENV=development

# MongoDB — local or Atlas
# Local:  mongodb://localhost:27017/velverse_taskflow
# Atlas:  mongodb+srv://<user>:<pass>@cluster.mongodb.net/velverse_taskflow
MONGO_URI=mongodb+srv://sample:sample@cluster0.nh8afhr.mongodb.net/?appName=Cluster0

# JWT Secrets — use long random strings (32+ chars)
JWT_SECRET=velverse_change_this_to_a_long_random_secret_2025
JWT_EXPIRES_IN=7d
REFRESH_SECRET=velverse_refresh_change_this_too_2025
REFRESH_EXPIRES_IN=7d

# Google OAuth (from console.cloud.google.com)
GOOGLE_CLIENT_ID=your_google_oauth_client_id
GOOGLE_CLIENT_SECRET=your_google_oauth_client_secret

# Razorpay (from razorpay.com → Settings → API Keys)
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# Flowise AI (your Flowise instance)
FLOWISE_BASE_URL=https://cloud.flowiseai.com
FLOWISE_API_KEY=your_flowise_api_key
FLOWISE_SOFTWARE_ID=your_flowise_software_id
FLOWISE_WEB_ID=your_web_id
FLOWISE_UIUX_ID=your_uiux_id
FLOWISE_MARKETING_ID=your_marketing_id
FLOWISE_DATA_ID=your_data_analysis_id

# Frontend URL (for CORS)
CLIENT_URL=http://localhost:3000
